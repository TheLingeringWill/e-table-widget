{
	"name": "widget",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@9.15.9",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "HOST=0.0.0.0 PORT=3002 node build",
		"update:maket": "pnpm remove maket && pnpm add maket@latest",
		"preview": "vite preview",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:integration": "playwright test",
		"test:unit": "vitest",
		"load-test": "tsx scripts/load-test-reservations.ts"
	},
	"devDependencies": {
		"@faker-js/faker": "^8.4.1",
		"@inlang/paraglide-js": "^2.18.0",
		"@playwright/test": "^1.49.1",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.21.1",
		"@sveltejs/vite-plugin-svelte": "5.0.3",
		"@types/eslint": "^8.56.12",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"autoprefixer": "^10.4.20",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"phosphor-svelte": "^2.0.1",
		"postcss": "^8.5.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "5.33.1",
		"svelte-check": "^3.8.6",
		"tailwindcss": "^3.4.17",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3",
		"vite": "^6.3.5",
		"vitest": "^1.6.0"
	},
	"type": "module",
	"dependencies": {
		"@floating-ui/dom": "^1.6.13",
		"@stripe/stripe-js": "^3.5.0",
		"cobe": "^0.6.3",
		"color2k": "^2.0.3",
		"dayjs": "^1.11.13",
		"devalue": "^5.1.1",
		"file-selector": "^0.6.0",
		"highlight.js": "^11.9.0",
		"intl-tel-input": "^24.8.2",
		"libphonenumber-js": "^1.11.10",
		"maket": "^0.0.203",
		"tailwind-merge": "^2.3.0",
		"tailwind-scrollbar": "^3.1.0",
		"valibot": "1.0.0-beta.15"
	}
}
