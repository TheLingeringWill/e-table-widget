{
	"name": "widget",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"update:maket": "pnpm remove maket && pnpm add maket@latest",
		"preview": "vite preview",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:integration": "playwright test",
		"update:flarepc": "pnpm add flarepc@latest",
		"test:unit": "vitest",
		"load-test": "tsx scripts/load-test-reservations.ts",
		"load-test:worker": "tsx scripts/load-test-reservations-worker.ts"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250109.0",
		"@faker-js/faker": "^8.4.1",
		"@playwright/test": "^1.49.1",
		"@sveltejs/kit": "^2.21.1",
		"@sveltejs/vite-plugin-svelte": "5.0.3",
		"@types/eslint": "^8.56.12",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"autoprefixer": "^10.4.20",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"phosphor-svelte": "^2.0.1",
		"postcss": "^8.5.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "5.33.1",
		"svelte-check": "^3.8.6",
		"tailwindcss": "^3.4.17",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3",
		"vite": "^6.3.5",
		"vitest": "^1.6.0"
	},
	"type": "module",
	"dependencies": {
		"@internationalized/date": "^3.7.0",
		"@jill64/sentry-sveltekit-cloudflare": "^2.0.6",
		"@prisma/client": "^6.8.2",
		"@sentry/sveltekit": "^9",
		"@stripe/stripe-js": "^3.5.0",
		"@sveltejs/adapter-cloudflare": "^5.0.1",
		"@sveltejs/adapter-vercel": "^5.7.2",
		"bits-ui": "^0.21.16",
		"dayjs": "^1.11.13",
		"devalue": "^5.1.1",
		"flarepc": "^0.0.55",
		"intl-tel-input": "^24.8.2",
		"maket": "^0.0.203",
		"postgres": "^3.4.5",
		"prisma-shared": "workspace:*",
		"shared": "workspace:*",
		"stripe": "^15.12.0",
		"svelte-rpc": "^1.0.1",
		"tailwind-scrollbar": "^3.1.0",
		"ulidx": "^2.4.1",
		"valibot": "1.0.0-beta.15",
		"worker": "workspace:*",
		"zod": "^3.24.1"
	}
}
